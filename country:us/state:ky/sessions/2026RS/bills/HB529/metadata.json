{
  "legislative_session": "2026RS",
  "identifier": "HB529",
  "title": "AN ACT relating to the Parole Board and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Boards And Commissions",
    "Governor",
    "Probation And Parole"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 439.320 to establish a term of 4 years for members of the Parole Board; allow the Governor to extend a term not more than 1 year if the expiration of the term causes more than 2 terms to expire in the same calendar year; allow the board to utilize panels of 2 or more members for parole and final parole revocation hearings; amend KRS 439.340 to change the time for parole review eligibility to 180 or more days to serve."
    }
  ],
