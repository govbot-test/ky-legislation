  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 211.492 to define \"advanced practice provider\"; amend  KRS 211.494 to allow Level IV verified trauma centers to utilize physician assistants and advanced practice registered nurses who are supervised by physicians to cover emergency departments; require the Department for Public Health to promulgate administrative regulations to conform."
    }
  ],
