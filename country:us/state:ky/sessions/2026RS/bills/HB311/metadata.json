{
  "legislative_session": "2026RS",
  "identifier": "HB311",
  "title": "AN ACT relating to railroad crossings.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Local Mandate",
    "State Agencies",
    "Traffic Safety",
    "Transportation"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 277 to require each railroad company to destroy or remove obstructive vegetation at intersections with public roads or highways; direct the Transportation Cabinet or local government to remove obstructive vegetation if the railroad company fails to do so after receiving written notice from the cabinet or local government; establish procedures for reimbursement by the railroad company for the vegetation removal."
    }
  ],
