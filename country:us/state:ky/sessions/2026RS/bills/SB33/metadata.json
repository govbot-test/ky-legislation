  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 222.504 to require the Cabinet for Health and Family Services to notify local governments when a recovery residence initiates the certification process with a certifying organization, becomes certified, or receives disciplinary action from the cabinet; require the cabinet to provide the recovery residence contact information and consider recovery residence information to be public record; amend KRS 222.510 to permit local governments to maintain a registry of recovery residences and consider the information a public record."
    }
  ],
