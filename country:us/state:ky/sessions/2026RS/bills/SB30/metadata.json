  "subject": [
    "Budget And Financial Administration",
    "Funds",
    "Motor Vehicles"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 190.058 to establish the motor vehicle commission fund; direct all license fees collected under KRS Chapter 190 to be deposited into the fund; set forth uses of the fund; provide that fund amounts not expended at the end of a fiscal year not lapse but instead be carried forward to the next fiscal year."
    }
  ],
