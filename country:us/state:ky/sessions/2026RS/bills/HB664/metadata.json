  "identifier": "HB664",
  "title": "AN ACT relating to civil remedies and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Actions",
