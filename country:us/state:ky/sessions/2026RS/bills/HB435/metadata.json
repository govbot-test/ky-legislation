  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 140.070 and 140.080 to include a foster child as a Class A beneficiary and to delete language that only applies to deaths occurring prior to July 1, 1995, or between July 1, 1995, and June 30, 1998; apply to estates of decedents who die on or after August 1, 2026."
    }
  ],
