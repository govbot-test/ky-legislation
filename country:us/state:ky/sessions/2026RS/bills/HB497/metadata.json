  "identifier": "HB497",
  "title": "AN ACT relating to postsecondary tuition waivers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aged Persons And Aging",
