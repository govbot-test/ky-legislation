  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Propose to amend Section 145 of the Constitution of Kentucky to restore the voting rights of persons convicted of certain felonies after completion of imprisonment, probation, or parole; provide ballot language; submit to voters for ratification or rejection."
    }
