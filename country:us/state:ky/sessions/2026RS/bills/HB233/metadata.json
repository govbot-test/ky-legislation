  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Propose to amend Section 172B of the Constitution of Kentucky to expand the freeze on an assessment or reassessment moratorium to include the development of property and to remove the 5-year expiration date for the moratorium; provide ballot language; submit to voters for ratification or rejection."
    }
