{
  "legislative_session": "2026RS",
  "identifier": "HB557",
  "title": "AN ACT relating to correctional services.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Budget And Financial Administration",
    "Contracts",
    "Corrections And Correctional Facilities, State",
    "Corrections Impact",
