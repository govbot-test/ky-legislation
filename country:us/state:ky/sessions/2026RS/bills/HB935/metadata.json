  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 342.260 to include a written notice of rejection or withdrawal of that rejection within the Insurance Coverage Look-up database; amend KRS 342.395 to require the commissioner of the Department of Workers' Claims to provide an online portal through which as employee's rejection or withdrawal may be electronically submitted to the department."
    }
