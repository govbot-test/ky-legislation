  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 16.175 to expand the criteria for determining when an Amber alert should be initiated to include when a child's disappearance may not have been voluntary and the physical safety of the child may be endangered and when a child is committed to the Department of Juvenile Justice or in the temporary custody of the Cabinet for Health and Family Services, a relative, or a nonrelative placement; provide that the Act may be cited as Wynter's law."
    }
  ],
