  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 405.021 to establish a clear and convincing standard of evidence in determining grandparent visitation; establish factors the court may consider in determining the best interests of the child; remove rebuttable presumption standard; amend KRS 620.090 to conform."
    }
  ],
