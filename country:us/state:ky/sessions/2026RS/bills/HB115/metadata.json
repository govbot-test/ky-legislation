  "identifier": "HB115",
  "title": "AN ACT relating to sales and use tax exemptions for menstrual discharge collection devices.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Reports Mandated",
