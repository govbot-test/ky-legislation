  "identifier": "HB621",
  "title": "AN ACT relating to class sizes for exceptional children and youth.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
