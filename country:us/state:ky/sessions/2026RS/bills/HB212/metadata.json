  "identifier": "HB212",
  "title": "AN ACT relating to rabies vaccinations.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Diseases",
    "Pets And Service Animals",
