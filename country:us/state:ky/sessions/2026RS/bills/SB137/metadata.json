  "legislative_session": "2026RS",
  "identifier": "SB137",
  "title": "AN ACT relating to a provisional license to practice medicine.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health And Medical Services",
    "Health Care Professionals",
    "Licensing",
    "Occupations And Professions",
    "Physicians"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 311.571 to allow and specify requirements for a physician licensed to practice medicine in another country to obtain a provisional license to practice medicine in the Commonwealth; specify requirements for a provisional license to convert to a regular license; add conditions for the Board of Medical Licensure to revoke a provisional license; make technical changes."
    }
  ],
