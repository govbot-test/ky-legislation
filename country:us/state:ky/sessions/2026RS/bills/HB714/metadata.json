  "identifier": "HB714",
  "title": "AN ACT relating to unborn children.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Attorney General",
    "Corrections Impact",
