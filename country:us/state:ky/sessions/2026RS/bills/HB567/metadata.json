  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 61.870 to change the definition of \"resident of the Commonwealth\"; amend KRS 61.872 to allow the official custodian of public records to require government-issued photo identification that includes an address from an applicant requesting to inspect records as proof that they are a resident of the Commonwealth; allow the agency to require a different form of identification or proof if the applicant does not possess photo identification; amend KRS 61.876 to conform."
    }
  ],
