  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 230.210 to redefine \"sports wagering\"; amend KRS 230.805 to change the age of access to sports wagering from 18 to 21; prohibit sports wagering licensees or service providers from offering proposition bets; amend KRS 2.015 to conform."
    }
