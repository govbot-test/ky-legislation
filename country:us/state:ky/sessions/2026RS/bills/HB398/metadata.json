{
  "legislative_session": "2026RS",
  "identifier": "HB398",
  "title": "AN ACT relating to decommissioning costs for electric generating units.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Boards And Commissions",
    "Coal",
    "Energy",
    "Oil And Natural Gas",
    "Public Utilities"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 278.264 to provide that the Public Service Commission maintains its authority to approve a utility's right to record and seek, prior to retirement authorization, the recovery of any electric generating unit's decommissioning, removal and salvage costs, and depreciation expenses through rates over the unit's estimated depreciable life."
    }
  ],
