  "identifier": "SB108",
  "title": "AN ACT relating to conditions of employment.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Actions",
    "Civil Rights",
