  "identifier": "HB179",
  "title": "AN ACT relating to children's health and welfare fiscal impact statements.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Attorney General",
