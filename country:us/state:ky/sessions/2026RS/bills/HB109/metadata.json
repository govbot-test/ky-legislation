  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 403.044 to establish that the 60-day waiting period for the presentation of testimony in a divorce proceeding involving minor children shall not apply where the parties have completed the collaborative law process or family mediation that has resulted in a final agreement that is filed with the court."
    }
  ],
