  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS 217.280 to 217.390, relating to food establishments,  to require a food service establishment that is required to provide calorie information for standard menu items under federal law to display information that menus are also available without calorie information upon request or on the food service establishment's website."
    }
