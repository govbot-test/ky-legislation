  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 29A.170 to increase juror pay from $5 per day to $15 per day and require that sequestered jurors be paid an additional $15 per day; amend KRS 32.011 to add local governmental units that may provide financial support for the court system and the offices of Commonwealth's attorneys serving that local community."
    }
