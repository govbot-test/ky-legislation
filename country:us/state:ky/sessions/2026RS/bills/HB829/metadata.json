  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 158.200 to require the board of education of a local school district to allow students to attend moral instruction when the moral instruction offering complies with the requirements enumerated; create a new section of KRS Chapter 158 to authorize the Attorney General to bring an action for a writ of mandamus to compel a board of education to comply; create a cause of action to permit a qualified individual to file a civil action against a board of education for injunctive relief arising from a violation of this Act; permit recovery of monetary damages for a willful and intentional violation; waive sovereign, governmental, and qualified immunity; prohibit retaliation."
    }
  ],
