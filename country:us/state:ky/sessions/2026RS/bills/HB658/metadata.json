  "identifier": "HB658",
  "title": "AN ACT relating to limited commercial driver's licenses and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Agriculture",
