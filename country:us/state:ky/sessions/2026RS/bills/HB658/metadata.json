  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 281A to require the Transportation Cabinet to promulgate emergency and ordinary administrative regulations to extend the allowable time length a limited CDL in accordance with the maximum length allowed under 49 C.F.R sec. 383.3; EMERGENCY."
    }
  ],
