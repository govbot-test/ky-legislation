  "identifier": "SB282",
  "title": "AN ACT relating to guardianship proceedings.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aged Persons And Aging",
    "Attorneys",
