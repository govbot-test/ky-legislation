{
  "legislative_session": "2026RS",
  "identifier": "HB476",
  "title": "AN ACT proposing to create a new section of the Constitution of Kentucky relating to reproductive rights.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Constitution, Ky.",
    "County Clerks",
    "Elections And Voting",
    "Local Mandate",
    "Reproductive Issues",
    "Secretary Of State"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Propose to create a new section of the Constitution of Kentucky to establish an individual right to reproductive freedom; allow the Commonwealth to regulate abortion after fetal viability, but not prohibit if medically needed to protect a pregnant patient's life or physical or mental health; forbid discrimination in enforcement of this right; prohibit prosecution of an individual, or a person helping a pregnant individual, for exercising the right to reproductive freedom; provide ballot language; submit to voters for ratification or rejection."
    }
  ],
