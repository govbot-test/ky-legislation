  "identifier": "HB741",
  "title": "AN ACT relating to personal delivery devices.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Highways, Streets, And Bridges",
