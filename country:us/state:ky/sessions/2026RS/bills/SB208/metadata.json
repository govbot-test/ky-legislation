  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 72.025 to require a post-mortem examination in deaths that occur during an arrest; create a new section of KRS Chapter 72 to require coroners to notify the Kentucky State Medical Examiner of arrest-related deaths; require publication of an annual public report; amend KRS 72.020 to conform."
    }
  ],
