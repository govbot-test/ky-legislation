  "identifier": "HB164",
  "title": "AN ACT relating to coverage for hearing aids and related services.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Actuarial Analysis",
    "Children And Minors",
    "Effective Dates, Delayed",
