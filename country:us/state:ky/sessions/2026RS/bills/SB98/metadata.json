    "Workforce"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 198B to establish requirements for projects using structural steel welding, such as hiring a certified welder and meeting national welding standards; define terms; exempt welding projects performed or requested on the premises of a homeowner or farmer; EFFECTIVE January 1, 2027."
    }
  ],
