{
  "legislative_session": "2026RS",
  "identifier": "SB98",
  "title": "AN ACT relating to welding safety.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Effective Dates, Delayed",
