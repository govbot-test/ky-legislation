  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 514.040, relating to theft by deception, to establish a presumption that a person creates or reinforces a false impression when the person lists or advertises residential or commercial real property for sale, lease, or rent without legal title or authority."
    }
  ],
