  "identifier": "HB162",
  "title": "AN ACT relating to identity documents.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Circuit Clerks",
    "Driver Licensing",
