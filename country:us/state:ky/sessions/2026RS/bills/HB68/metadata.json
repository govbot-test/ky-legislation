  "identifier": "HB68",
  "title": "AN ACT relating to planning and zoning.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Consolidated Local Governments",
    "Counties",
    "Land Use",
