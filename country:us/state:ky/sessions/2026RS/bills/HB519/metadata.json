  "legislative_session": "2026RS",
  "identifier": "HB519",
  "title": "AN ACT relating to identity documents.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Disabilities",
    "Driver Licensing",
