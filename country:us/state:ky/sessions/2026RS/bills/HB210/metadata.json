  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 337.010 to define \"job posting\" and \"wage range\"; create a new section of KRS Chapter 337 to require all employers to include the wages or wage range for the advertised position in any job posting; amend KRS 95A.250 and 337.020 to conform."
    }
