  "identifier": "HB542",
  "title": "AN ACT relating to eminent domain and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Civil Actions",
