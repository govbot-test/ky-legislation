  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 64.012 to increase and modify fees received by the county clerk; after January 1, 2027, allow recalculation using the CPI-U, with the fee increase going to the Affordable Housing Trust Fund; apply to fees received by county clerks for services provided on or after August 1, 2026."
    }
  ],
