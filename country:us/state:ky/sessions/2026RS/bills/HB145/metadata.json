  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 64 to allow the State Treasurer, Auditor of Public Accounts, Secretary of State, Commissioner of Agriculture, and Attorney General to employ persons exempt from approval requirements of the classified service as deemed necessary or advisable to make and carry out policy; permit the State Treasurer, Auditor of Public Accounts, Secretary of State, Commissioner of Agriculture, and Attorney General to increase, by administrative order, the salary of any classified employee with status up to the midpoint of the grade of the employee's classification."
    }
  ],
