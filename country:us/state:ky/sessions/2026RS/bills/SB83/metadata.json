  "identifier": "SB83",
  "title": "AN ACT relating to forcible entry and detainer.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Actions",
    "Civil Procedure",
    "Courts, District",
