  "identifier": "HB590",
  "title": "AN ACT relating to benefits for Kentucky National Guard members.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education, Higher",
    "Military Affairs And Civil Defense",
    "National Guard",
    "Universities And Colleges"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 164.5161 to define \"spouse\"; rename the National Guard Tuition Award Program the National Guard Tuition Scholarship Program; allow current National Guard members and their spouses up to 130 total credit hours at a postsecondary institution; allow the total number of credit hours to be transferrable between the member and his or her spouse; grant authority to the adjutant general to award up to 45 additional nontransferable credit hours within the program; amend KRS 164.5165 and 164.5169 to conform."
    }
  ],
