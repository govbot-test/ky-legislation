{
  "legislative_session": "2026RS",
  "identifier": "HB194",
  "title": "AN ACT relating to cigar bars.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Alcoholic Beverages",
    "Cities",
