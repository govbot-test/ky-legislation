  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 533.020 to provide the court 60 days after the expiration of any period of supervision to determine if a violation of the period of supervision has occurred and any appropriate action; provide that a period of supervision shall be tolled between the issuance of a warrant for any violation of supervision and the defendant's first appearance before the court after service of the warrant."
    }
  ],
