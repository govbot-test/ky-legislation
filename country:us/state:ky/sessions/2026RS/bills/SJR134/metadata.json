{
  "legislative_session": "2026RS",
  "identifier": "SJR134",
  "title": "A JOINT RESOLUTION regarding utility fuel adjustment clauses under the jurisdiction of the Public Service Commission and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Effective Dates, Emergency",
    "Energy",
    "Fuel",
    "Public Utilities"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Order the Public Service Commission to open a new or include in an existing administrative case by May 15, 2026, to review the fuel adjustment charge to reduce volatility in the surcharge; receive comments from the public and affected parties on the fuel adjustment charge; and issue an order and amend the administrative regulation on the fuel adjustment charge by August 15, 2026; provide a report to the Legislative Research Commission by December 15, 2026; EMERGENCY."
    }
  ],
