  "identifier": "HB237",
  "title": "AN ACT relating to the employer student loan repayment credit.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education, Higher",
    "Reports Mandated",
    "Taxation",
