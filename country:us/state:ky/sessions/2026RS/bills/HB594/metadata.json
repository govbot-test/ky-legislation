  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS 17.500 to 17.580, relating to the sex offender registry, to define \"costume\" and \"Halloween-related activity\"; prohibit sex offenders who have committed a criminal offense against a victim who is a minor from participating in any Halloween-related activity; establish penalties."
    }
  ],
