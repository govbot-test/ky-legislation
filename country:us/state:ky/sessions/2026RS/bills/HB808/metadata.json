    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 91A.400 to authorize all home rule class cities to levy a restaurant tax; remove the Department for Local Government registration mandate; and remove the restriction on the use of the funds; amend KRS 67.938 to conform."
    }
