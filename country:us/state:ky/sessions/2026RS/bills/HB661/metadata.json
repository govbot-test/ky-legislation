  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 162.055 to allow public school property to be utilized for employee housing; create a new section of KRS Chapter 162 to allow school boards or school district finance corporations to use property currently owned or newly leased to provide housing options for employees upon a determination that the use of land serves the educational purposes of the school district; make technical changes."
    }
  ],
