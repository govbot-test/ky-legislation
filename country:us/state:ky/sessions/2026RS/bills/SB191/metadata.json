  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 199 to define terms; create the Kentucky Kindergarten Readiness Performance-Based Child-Care Incentive Pilot Program; require the University of Kentucky to operate the pilot program; establish the purpose and directives of the pilot program; establish completion date and reporting requirements."
    }
  ],
