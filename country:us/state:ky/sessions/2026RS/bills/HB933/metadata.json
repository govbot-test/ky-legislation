  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 241.065 to prohibit licensure for a quota retail package premises less than 1 mile from another quota retail package license premises in a county containing a city of the first class; exempt existing quota retail package license premises; allow for loss of exemption for an existing quota retail package license premises under designated circumstances."
