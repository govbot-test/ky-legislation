  "identifier": "HB138",
  "title": "AN ACT relating to the compensation of coroners.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Consolidated Local Governments",
    "Coroners",
    "Counties",
