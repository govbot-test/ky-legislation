  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 217.015 to add tallow-based cosmetic products to the definition of \"home-based processor\"; amend KRS 217.136  to allow home-based processors to produce tallow-based cosmetic products in accordance with the registration and regulation requirements set forth by the Cabinet for Health and Family Services."
    }
  ],
