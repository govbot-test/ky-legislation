{
  "legislative_session": "2026RS",
  "identifier": "SB198",
  "title": "AN ACT relating to operations in the Office of the Attorney General.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Advisory Boards, Commissions, And Committees",
    "Attorney General",
    "Background Checks",
    "Boards And Commissions",
    "Civil Actions",
    "Civil Procedure",
    "Consumer Protection",
    "Courts, Circuit",
