  "identifier": "HB120",
  "title": "AN ACT relating to cosmetology.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Barbers And Cosmetologists",
