  "identifier": "SB157",
  "title": "AN ACT relating to total net income limits on loans secured by a mortgage.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Banks And Financial Institutions",
    "Loans, Credit, Interest, And Usury",
    "Real Estate"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 286.8-125 to exempt loans for which the total points and fees do not exceed the threshold set forth in 12 C.F.R. sec. 1026.43(e)(3) from total net income limits; make technical amendments; direct that the Act applies to contracts entered into on or after the effective date of the Act."
    }
  ],
