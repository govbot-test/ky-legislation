  "legislative_session": "2026RS",
  "identifier": "HB488",
  "title": "AN ACT relating to the Medicaid home and community based waiver program.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Aged Persons And Aging",
