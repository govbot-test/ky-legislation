{
  "legislative_session": "2026RS",
  "identifier": "HB608",
  "title": "AN ACT relating to nondisclosure and confidentiality agreements.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children And Minors",
