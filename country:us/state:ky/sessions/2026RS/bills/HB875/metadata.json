  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 156 to define terms; establish a nonpublic school student's eligibility for participation in interscholastic athletics at the public school to which the student would be assigned in the student's district of residence; establish requirements, conditions, and procedures for the nonpublic school student's participation in interscholastic athletics."
    }
  ],
