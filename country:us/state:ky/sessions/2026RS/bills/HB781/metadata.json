  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 205.2003 to require the cabinet develop and implement a Supplemental Nutrition Assistance Program, also known as SNAP, education and training plan amendment to promote improved employment outcomes and workforce participation related to healthy workforce habits through public-private partnerships."
    }
  ],
