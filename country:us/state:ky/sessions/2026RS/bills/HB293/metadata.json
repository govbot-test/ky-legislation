{
  "legislative_session": "2026RS",
  "identifier": "HB293",
  "title": "AN ACT relating to vehicle wheels.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Highways, Streets, And Bridges",
    "Motor Vehicles",
    "Traffic Safety",
    "Transportation"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 189 to require vehicles operating on a highway with an iron, steel, or wooden wheel to be equipped with a rubberized strip on the portion of the wheel that is in contact with the highway; provide an exception for certain animal-drawn vehicles; amend KRS 189.990 to set penalty for violation at $20 to $100 for each offense."
    }
  ],
