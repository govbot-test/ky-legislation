{
  "legislative_session": "2026RS",
  "identifier": "HB254",
  "title": "AN ACT relating to temporary structures.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Housing, Building, And Construction",
    "Local Mandate"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 198B.050 to exempt certain temporary structures from state building code compliance if erected by or for a state or government agency, city, or municipality; require a temporary structure to be inspected and brought into compliance or removed after 6 months; exempt portable or temporary shower or toilet units from state building code compliance if intended to be used for less than 6 months; require a portable or temporary shower or toilet unit to be inspected and brought into compliance or removed after 6 months."
    }
  ],
