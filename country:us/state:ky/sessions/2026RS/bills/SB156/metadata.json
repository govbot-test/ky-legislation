  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 402.020 to prohibit marriage with a person under 18 years of age; exclude from being prohibited and void, marriages entered into in the Commonwealth before the effective date of this Act and marriages entered into in another state or country; amend KRS 402.080 and 402.210 to prohibit the issuance of marriage licenses to persons under 18 years of age; amend KRS 402.030 to conform; repeal KRS 402.205, relating to petitions to courts filed by minors aged 17 years seeking permission to marry."
    }
  ],
