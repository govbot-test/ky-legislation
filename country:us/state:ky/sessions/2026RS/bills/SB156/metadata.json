  "identifier": "SB156",
  "title": "AN ACT relating to child marriage.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children And Minors",
    "Civil Actions",
