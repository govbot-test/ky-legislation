  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 164.020 to direct the Council on Postsecondary Education to postpone the approval of any new program at a state postsecondary educational institution if the institution has not met its equal educational opportunity goals; amend KRS 164.011, 164.131, 164.321, 164.821, and 335B.010 to conform; repeal KRS 164.2894, 164.2895, 164.2896, 164.2897, 164.2898. 164.2899, and 335B.035; provide that the Act may be cited as the  Restoration of Postsecondary Inclusion and Student Success Programs Act."
    }
  ],
