  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 154.32-010, relating to the Kentucky Business Investment Program, to add laboratory equipment, computer servers, software, capitalized leases, and leasehold improvements directly related to research and development, headquarters, high-technology operations, or service sector facilities to the definitions of \"eligible costs\" and \"start-up costs,\" respectively."
    }
  ],
