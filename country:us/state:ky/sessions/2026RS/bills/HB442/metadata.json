  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 61.7991 to add state and federal prosecutors and public defenders to the definition of \"covered person\"; authorize standing for a civil action for injunctive or declaratory relief for unauthorized disclosure; provide that the removal of information does not apply to financial disclosures required under KRS Chapter 61."
    }
  ],
