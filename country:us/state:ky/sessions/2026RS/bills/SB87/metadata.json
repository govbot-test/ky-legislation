    "Treasurer"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 66.480 to allow local government and school district investments in United States obligations by a repurchase agreement with a credit union and in interest-bearing accounts issued through a credit union; amend KRS 41.010 to redefine \"bank\" and \"state depository\" to include credit unions; amend KRS 41.070 to prohibit receipts from being held, used, or deposited in a personal or special credit union account; amend KRS 41.220 to allow credit unions to be designated as state depositories; amend KRS 41.240, 41.250, 41.300, 30A.120, and 30A.200 to conform."
    }
  ],
