  "identifier": "SB87",
  "title": "AN ACT relating to the provision of financial services and products by credit unions.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Banks And Financial Institutions",
    "Education, Finance",
