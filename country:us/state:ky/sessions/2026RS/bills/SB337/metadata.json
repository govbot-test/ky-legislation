  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 15.808 to allow the Attorney General to pass through child support payments up to $200 per month to recipients of public assistance; require that the payments are not considered income for the purpose of determining public assistance eligibility or the recipient monthly benefit amount."
    }
