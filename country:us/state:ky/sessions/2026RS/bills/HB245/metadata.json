  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Propose to amend Section 170 of the Constitution of Kentucky to increase the homestead exemption to $75,000; require the homestead exemption amount to be indexed every year; provide ballot language; submit to voters for ratification or rejection; apply to property assessments beginning on or after January 1, 2027."
    }
  ],
