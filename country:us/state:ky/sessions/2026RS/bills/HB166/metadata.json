  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 39A to establish the position of chief resiliency officer, appointed by the Governor, to lead disaster preparedness and resiliency efforts; amend KRS 39A.070 to include cooperation with chief resiliency officer in the powers, responsibility, and duties of the director of the Division of Emergency Management."
    }
  ],
