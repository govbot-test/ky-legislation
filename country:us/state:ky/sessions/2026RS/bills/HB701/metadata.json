  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 403 to provide that postnuptial agreements are void and unenforceable unless the document meets certain requirements and 60 days have elapsed between initial receipt of the document and its execution."
    }
