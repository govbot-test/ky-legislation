  "identifier": "HB539",
  "title": "AN ACT relating to foreign laws.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Contracts",
