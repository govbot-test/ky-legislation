  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 446 to prohibit the recognition of adjudicative rulings or contractual provisions based in whole or in part upon Sharia or any foreign law; provide for exceptions for ecclesiastical matters, voluntary choice of law for corporate entities, or where federal preemption applies."
    }
  ],
