  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 154.12 to establish the Kentucky Talent Recruitment Grant Program under the Cabinet for Economic Development; define terms; establish the duties of the cabinet in implementation of the program subject to approval of the Kentucky Economic Development Finance Authority; establish eligible grant applicants' duties and program reporting requirements; establish the Kentucky Talent Recruitment Grant Program fund; APPROPRIATION; EMERGENCY."
    }
  ],
