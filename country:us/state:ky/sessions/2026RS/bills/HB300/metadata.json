  "identifier": "HB300",
  "title": "AN ACT relating to contractors.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Consumer Protection",
