  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 141 to establish the employers' organ and bone marrow donation tax credit; amend KRS 141.0205 to provide the ordering of the credit; amend KRS 131.190 to allow disclosure of certain information on the credit to the Legislative Research Commission; provide that Section 1 of this Act may be cited as the Living Organ and Bone Marrow Donor Assistance Act of 2026."
    }
  ],
