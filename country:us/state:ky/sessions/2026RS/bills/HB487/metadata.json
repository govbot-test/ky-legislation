  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 314 to define terms; establish the Kentucky Advisory Council of Licensed Lactation Consultants under the Board of Nursing and list the powers and duties of the council; require the board to promulgate administrative regulations relating to licensed lactation consultants; permit the board to require a criminal background investigation of an applicant for a license as a licensed lactation consultant by means of a criminal background check; establish provisions for penalties."
    }
  ],
