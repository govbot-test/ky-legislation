  "identifier": "HB225",
  "title": "AN ACT relating to a tax credit for volunteer firefighters.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Firefighters And Fire Departments",
    "Reports Mandated",
