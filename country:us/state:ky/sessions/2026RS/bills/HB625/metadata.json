  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 65.8808 to expressly include failure to stop at a red traffic control signal and speeding as crimes subject to code enforcement; amend KRS 189.990 to provide that a person may be subject to a civil offense for failure to stop at a red traffic control signal or for speeding violations if not cited by a police officer at the time of the violation."
    }
  ],
