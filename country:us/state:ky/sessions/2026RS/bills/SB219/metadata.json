  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 286.9-140 to require the commissioner of the Department of Financial Institutions to impose a $3 fee per deferred deposit transaction for data required to be submitted by a deferred deposit service business licensee; direct that the Act applies to deferred deposit transactions entered or or after the effective date of the Act."
    }
  ],
