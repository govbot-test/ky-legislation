  "legislative_session": "2026RS",
  "identifier": "HB434",
  "title": "AN ACT relating to posthumous name changes.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Courts, District",
    "Crime Victims",
    "Deaths"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 401.010 to allow a family member of a deceased person to posthumously change the deceased person's name if the name is the result of marriage to a person arrested for or charged with committing an offense intentionally, knowingly, or wantonly, which resulted in the death of the deceased;  provide that the order of priority of family members is the same as in KRS 367.93117."
    }
  ],
