  "identifier": "HB782",
  "title": "AN ACT relating to postsecondary education students.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children And Minors",
    "Education, Higher",
