  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 42 to define terms; require the Finance and Administration Cabinet to establish a grant database that will be a central repository for information on all available state or local government grants; require state and local agencies to report grant opportunities to the Finance and Administration Cabinet for inclusion in the grant database."
    }
  ],
