  "legislative_session": "2026RS",
  "identifier": "HB375",
  "title": "AN ACT relating to automated license plate readers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections Impact",
    "Crimes And Punishments",
    "Technology",
