  "identifier": "HB405",
  "title": "AN ACT relating to occupational license fees levied by a board of education.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Courts, Fiscal",
