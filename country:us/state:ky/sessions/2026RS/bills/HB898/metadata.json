  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 160 to define terms; require local boards of education and local associations to bargain collectively; provide that a party who violates the duty to bargain collectively is required to pay to the aggrieved party no more than $500."
    }
  ],
