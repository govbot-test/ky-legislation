  "identifier": "SB63",
  "title": "AN ACT relating to student journalist freedom.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Rights",
    "Education, Elementary And Secondary",
    "Media",
