  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 171 to establish the Kids Love to Read Program; specify the program is for children in kindergarten through grade 5; require books to be sent to children's homes; require the Department for Libraries and Archives to promulgate administrative regulations necessary to administer the program; appropriate $500,000 in fiscal year 2027-2028 to support the program; APPROPRIATION."
    }
  ],
