  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 65.016 and 337.275 to allow a local government to adopt and enforce an ordinance that requires a minimum wage at a rate higher than that found in KRS 337.275 for employers located within that government's jurisdiction."
    }
