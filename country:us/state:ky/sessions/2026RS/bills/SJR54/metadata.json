  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Direct the Department for Libraries and Archives and the Cabinet for Health and Family Services to cooperate in exploring ways to increase enrollment in Dolly Parton's Imagination Library Program; direct the department and the cabinet to submit a report on the progress of identifying ways of increasing enrollment in the program to the Governor and the Legislative Research Commission by November 1, 2026."
    }
  ],
