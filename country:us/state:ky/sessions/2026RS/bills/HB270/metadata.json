  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 337.275 to raise the minimum wage for employers to $9.50 an hour beginning on the effective date of this Act and incrementally thereafter to $15 an hour beginning on July 1, 2030; raise the state minimum wage for tipped employees to $5 an hour beginning on the effective date of this Act."
    }
  ],
