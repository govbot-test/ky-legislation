  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS 344.030 to 344.110 to prohibit employers from considering or requiring disclosure of prior criminal history as part of the initial job application; provide that the Act may be cited as the Ban the Box - The Criminal Record Employment Discrimination Act."
    }
  ],
