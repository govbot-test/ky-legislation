{
  "legislative_session": "2026RS",
  "identifier": "SB278",
  "title": "AN ACT relating to the Department of Kentucky State Police.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Motor Vehicles",
    "Police, State",
    "State Agencies"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 16.060 to require the commissioner of the Department of Kentucky State Police to authorize officers of the department to engage in certain types of law enforcement-related off-duty employment; require the commissioner to establish policies and procedures for off-duty employment; amend KRS 16.070 to require the commissioner of the Department of Kentucky State Police to establish policies and procedures related to the use of uniforms, equipment, and facilities for off-duty employment; amend KRS 44.045 to allow officers of the Department of Kentucky State Police to use motor vehicles with regular license plates for off-duty employment."
    }
  ],
