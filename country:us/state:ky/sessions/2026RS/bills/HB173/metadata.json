  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 258.005 to define \"veterinarian\" and \"veterinary technician\"; amend KRS 258.015 to require that a Kentucky-licensed veterinary technician authorized to vaccinate a dog, cat, or ferret against rabies be under the direct supervision of a veterinarian that is located on the premises of the facility."
    }
  ],
