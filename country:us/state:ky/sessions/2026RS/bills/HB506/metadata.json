  "identifier": "HB506",
  "title": "AN ACT relating to the Department of Fish and Wildlife Resources.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Boats And Boating",
    "Communications",
