  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 6 to allow members and members-elect of the General Assembly to prefile bills and resolutions for introduction at the next succeeding regular legislative session; require the prefiled bills and resolutions to be published on the Legislative Research Commission's website."
    }
