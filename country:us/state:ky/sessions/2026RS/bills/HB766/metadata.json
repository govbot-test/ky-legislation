  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 164 to prohibit public postsecondary education institutions from requiring a student who is within 6 months of turning 18 years of age or older to reside in student housing; provide exceptions."
    }
