  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 190.046 to define \"parts,\" \"qualifying repair,\" \"qualifying repair order,\" \"repair order,\" \"warranty,\" and \"warranty work\"; establish requirements for dealer performance of warranty work, including time allowances, labor rates, parts markups, and payment procedures and terms."
    }
  ],
