  "identifier": "HB55",
  "title": "AN ACT relating to the rights of parents.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children And Minors",
    "Civil Actions",
