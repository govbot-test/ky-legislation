  "identifier": "HB443",
  "title": "AN ACT relating to sex crimes.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections Impact",
    "Crimes And Punishments",
    "Criminal Procedure",
    "Education, Elementary And Secondary",
