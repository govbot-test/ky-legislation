  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 334A.035 to remove the requirement of needing to complete postgraduate professional experience to be completed under the supervision of a speech-language pathologist who holds a Kentucky license; amend KRS 334a.050, 334A.020, and 344A.085 to conform."
    }
