  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 116.035 to provide that a voter shall be deemed a resident of a city within the county of his or her habitation if the voter has at least 50% ownership in real property located within the city precinct."
    }
