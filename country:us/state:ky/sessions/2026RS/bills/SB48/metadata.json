  "legislative_session": "2026RS",
  "identifier": "SB48",
  "title": "AN ACT relating to mandatory reentry supervision.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections Impact",
    "Courts",
