  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 141.020 to establish a graduated tax rate for net income of $300,000 or less; establish a flat tax rate of 6% for net incomes in excess of $300,000; and remove provisions relating to tax rate reduction procedures."
    }
  ],
