  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 259.120 to allow the county judge/executive to contract for the performance of specific duties required to be performed when an equine is subject to being taken up by a person or organization that provides animal sheltering services; require the contract to be approved by the county fiscal court; establish immunity from criminal and civil liability."
    }
  ],
