  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 11 to require the Governor to request permission from the State Treasurer to use tax dollars for international travel; prohibit the use of tax dollars for international travel by the Governor without approval."
    }
