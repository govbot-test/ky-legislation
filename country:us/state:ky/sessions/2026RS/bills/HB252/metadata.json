  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 61.702 and 78.5536 to provide full hospital and medical insurance benefits for a member, their spouse, and their dependents if the member becomes disabled in line of duty with a hazardous disability; EMERGENCY."
    }
