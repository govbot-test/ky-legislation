  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 411 to establish a cause of action for a person who was wrongfully convicted of a felony in the Commonwealth; specify amounts of damages that may be awarded to claimants; establish the wrongful conviction compensation fund."
    }
