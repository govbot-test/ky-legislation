{
  "legislative_session": "2026RS",
  "identifier": "SB65",
  "title": "AN ACT relating to deficient administrative regulations and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Drugs And Medicines",
    "Effective Dates, Emergency",
