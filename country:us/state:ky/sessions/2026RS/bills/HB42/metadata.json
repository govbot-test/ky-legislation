  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 164 to declare findings; set mandated annual varsity athletic game requirements for the University of Kentucky, the University of Louisville, Eastern Kentucky University, Kentucky State University, Morehead State University, Murray State University, Northern Kentucky University, and Western Kentucky University in various sports; ensure existing contracts of public postsecondary institutions are not violated."
    }
