  "identifier": "HB686",
  "title": "AN ACT relating to the Kentucky Positive Youth Development Commission.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advisory Boards, Commissions, And Committees",
