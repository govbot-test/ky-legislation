{
  "legislative_session": "2026RS",
  "identifier": "HB314",
  "title": "AN ACT relating to the Kentucky Communications Network Authority and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advisory Boards, Commissions, And Committees",
