  "identifier": "SB288",
  "title": "AN ACT relating to the rights of tenants.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Landlord And Tenant",
    "Local Government",
