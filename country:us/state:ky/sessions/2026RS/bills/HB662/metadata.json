{
  "legislative_session": "2026RS",
  "identifier": "HB662",
  "title": "AN ACT relating to the regulation of low voltage battery-charged security fences by local governments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cities",
