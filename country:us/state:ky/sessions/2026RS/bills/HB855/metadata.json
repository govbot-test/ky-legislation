  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 116.025 to permit voters 16 and 17 years of age to vote in local school board elections upon local approval by a school board; create a new section of KRS Chapter 116 to require county clerks to administer the registration and voting of persons 16 and 17 years of age; allow voters who are 16 and 17 years of age to receive ballots limited to school board contests; require the State Board of Elections to promulgate administrative regulations to establish the procedure for persons 16 and 17 years of age to register and vote for school board elections."
    }
  ],
