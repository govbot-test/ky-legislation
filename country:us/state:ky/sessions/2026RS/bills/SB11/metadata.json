{
  "legislative_session": "2026RS",
  "identifier": "SB11",
  "title": "AN ACT relating to a residential safe room rebate program.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
