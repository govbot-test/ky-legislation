  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 177.240 to prohibit the Transportation Cabinet or any county or city that maintains a limited access facility from requiring a property owner to pay compensation for any increase in property value attributable to the new access as a condition of allowing a property owner access."
    }
  ],
