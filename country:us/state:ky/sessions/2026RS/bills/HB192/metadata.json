  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 314.011 to define \"dispense\" or \"dispensing\" if prescribed, as receiving and distributing nonscheduled legend drugs; include receiving and distributing nonscheduled legend drug samples from pharmaceutical manufacturers; define \"dispense\" or \"dispensing\" for an advanced practice registered nurse as the same as in KRS 315.010."
    }
