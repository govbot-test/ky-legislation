  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 158.192 to require a local board of education to allow parents and guardians an opportunity to orally recite passages from materials, programs, or events that are subject to appeal; require immediate removal of the material, program, or event if the board denies a parent or guardian the opportunity to orally recite passages."
    }
  ],
