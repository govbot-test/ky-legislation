  "identifier": "SB251",
  "title": "AN ACT relating to the Department of Corrections.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Corrections And Correctional Facilities, State",
    "Corrections Impact",
    "Crimes And Punishments",
