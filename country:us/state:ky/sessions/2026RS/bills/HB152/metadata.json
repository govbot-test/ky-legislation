  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 141.020, relating to the individual income tax, to establish graduated individual income tax rates for taxable years beginning on or after January 1, 2027; remove provisions relating to tax rate reduction procedures."
    }
