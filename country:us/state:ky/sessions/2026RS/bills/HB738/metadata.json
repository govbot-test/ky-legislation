  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 341.350, relating to unemployment insurance, to lengthen the verified definite return-to-work or recall-to-work period from 16 weeks to 12 months and add protections for employees whose place of employment can reasonably be expected to resume operations within 12 months following a natural disaster."
    }
  ],
