{
  "legislative_session": "2026RS",
  "identifier": "HB456",
  "title": "AN ACT relating to the State Treasurer and unclaimed property.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Commendations And Recognitions",
    "Minerals And Mining",
    "Property",
    "Treasurer"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 2 establishing the fourth week of September of each year to be Unclaimed Property Week; amend KRS 41.020 to remove Treasurer's requirement to maintain his or her residency at the seat of government; amend KRS 393A.020 to remove mineral proceeds from the KRS list of property to which the chapter does not apply; amend KRS 393A.740 to include deficient reports as punishable by civil penalty."
    }
  ],
