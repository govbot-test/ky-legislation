  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 382.110 to establish that a municipal government may initiate a cause of action to compel the filing of a commissioner's deed if more than 30 business days have passed since the grantee's receipt of the deed from the commissioner; establish available relief; make technical corrections."
    }
  ],
