  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 17 to define terms and require criminal justice agencies to provide criminal history records information to requesting agencies when they are conducting a basic suitability or fitness assessment for federal or contractor employees under 5 U.S.C. sec. 9101; authorize the agency to request a fee of $25 for reimbursement of expenses related to the check from entities other than the Commonwealth; amend KRS 610.340, relating to juvenile justice records, to conform."
    }
  ],
