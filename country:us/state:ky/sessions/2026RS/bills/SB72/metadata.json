  "identifier": "SB72",
  "title": "AN ACT relating to the recruitment and retention of health care professionals and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Actions",
    "Effective Dates, Emergency",
