  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 336.130 to delete references prohibiting employees becoming a member of a labor or organization as a condition of employment; amend KRS 336.990 to conform; amend KRS 67A.6904, 67C.406, 70.262, 78.470, 78.480, and 345.050 to remove exceptions; amend KRS 336.1341 and 336.135 to conform; repeal KRS 65.016, 336.132, and 336.134."
    }
  ],
