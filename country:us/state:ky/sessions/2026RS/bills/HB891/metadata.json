  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 134.810 to require the proration of motor vehicle property taxes when a motor vehicle is transferred between private parties; set requirements for the proration; require any overpayments created from the proration requirements to be refunded without written request; apply to motor vehicle transfers occurring on or after January 1, 2027."
    }
  ],
