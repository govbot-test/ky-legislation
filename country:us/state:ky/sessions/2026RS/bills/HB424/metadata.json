  "identifier": "HB424",
  "title": "AN ACT relating to social work.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Background Checks",
    "Boards And Commissions",
