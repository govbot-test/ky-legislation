  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 142.400 to impose a 1% statewide surtax on the rental of accommodations when charged by the owner of the property or by a person facilitating the rental of the property and deposit the receipts from the surtax into the affordable housing trust fund; amend KRS 142.402, 142.404, 142.406, and 198A.190 to conform; EFFECTIVE August 1, 2026."
    }
  ],
