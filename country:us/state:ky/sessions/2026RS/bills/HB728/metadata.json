  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 525.080 to enhance the penalty for a harassing communications second offense to a Class A misdemeanor; enhance the penalty for a harassing communications third or subsequent offense and an offense where a person conceals his or her identity to a Class D felony."
    }
