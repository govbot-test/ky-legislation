  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 335B to prohibit using a professional title, term, or abbreviation or holding oneself out as licensed or certified to practice a profession without holding a valid license or certification; provide that a violation is a Class B misdemeanor."
    }
  ],
