  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 164 to require the Council on Postsecondary Education to promulgate administrative regulations to prohibit the use of public funds towards a degree in a low-earning outcome program; require the council to provide an annual report on the implementation of the prohibition to the Legislative Research Commission."
    }
  ],
