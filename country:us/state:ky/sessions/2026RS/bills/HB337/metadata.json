  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 383 to allow landlords to terminate rental agreements upon 3 days' notice when law enforcement or fire protection services are dispatched to a property more than 3 times in a 6-month period and set refund provisions."
    }
  ],
