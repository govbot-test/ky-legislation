  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 216 to protect access to assisted reproductive technology; create a new section of KRS Chapter 311 to declare that a fertilized human egg or human embryo that exists outside of the uterus of a human body shall not be considered an unborn child, a minor child, a natural person, or any other term that connotes a human being for any purpose under state law."
    }
  ],
