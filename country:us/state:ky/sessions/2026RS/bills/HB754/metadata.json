  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 83A.040 to increase the term of office for city legislative body members in cities with populations of 12,000 or more to terms of 4 years; provide guidance for the transition of the members who will have longer terms of office after the effective date of the Act."
