  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 161.030 to specify the Education Professional Standards Board has authority only over educators hired by public schools; amend KRS 199.894 to define \"learning pod\" and exclude learning pods from the definition of \"child-care center\" and \"family child-care home\"; amend KRS 194A.381 to exclude learning pods from certain youth camp requirements."
    }
