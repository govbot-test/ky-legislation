  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 65 to provide incremental revenue tax incentives to the Rural Kentucky Revitalization Opportunity Partnership; define terms; state findings; establish the Rural Kentucky Revitalization Opportunity Partnership Board; establish incentive program; create an income tax credit for certain residents; amend KRS 141.0205 to order the credit; amend KRS 131.190 to allow reporting by the Department of Revenue."
    }
