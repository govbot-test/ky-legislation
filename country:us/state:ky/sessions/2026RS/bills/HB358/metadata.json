  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS 164.740 to 164.7891 to establish a coal county paramedic scholarship to be administered by the Kentucky Higher Education Assistance Authority (KHEAA); define terms; establish a fund in the State Treasury to be administered by KHEAA for providing coal county paramedic scholarships."
    }
