{
  "legislative_session": "2026RS",
  "identifier": "HB305",
  "title": "AN ACT relating to grand jury service.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections Impact",
    "Courts",
    "Crimes And Punishments",
    "Criminal Procedure",
    "Local Mandate"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 29A to establish that a person present at any part of a grand jury proceeding shall not knowingly record the proceeding or disclose any information gathered while present during a proceeding; amend KRS 29A.990 to establish the penalty for knowingly recording or disclosing information gathered at a grand jury proceeding as a Class A misdemeanor unless the person is a public servant as defined in KRS 519.010, in which case it is a Class D felony; amend KRS 500.050 to provide that a misdemeanor violation of knowingly recording or disclosing information gathered at a grand jury proceeding shall be prosecuted within 10 years after the act is committed."
    }
  ],
