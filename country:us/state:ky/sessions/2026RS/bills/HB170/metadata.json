  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 446.350 to define terms; outline appropriate relief if a government substantially burdens a person's sincerely held religious belief; apply to laws adopted before or after the effective date; include severability clause; waive sovereign and governmental immunity."
    }
  ],
