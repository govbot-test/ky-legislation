  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 341.243 to change the employer's contribution rate to the service capacity upgrade fund; of the rate subtracting .075% until December 31, 2026; provide that beginning January 1 2027, the rates shall be adjusted by subtracting 0.0115%; require the secretary of the Education and Labor Cabinet to set the adjustment percentage annually to be effective January 1 of each subsequent year, not to exceed 1.025%."
    }
  ],
