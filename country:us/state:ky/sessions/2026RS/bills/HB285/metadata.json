{
  "legislative_session": "2026RS",
  "identifier": "HB285",
  "title": "AN ACT relating to a property tax homestead exemption for disabled veterans.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aged Persons And Aging",
    "Cities",
    "Counties",
    "Disabilities",
