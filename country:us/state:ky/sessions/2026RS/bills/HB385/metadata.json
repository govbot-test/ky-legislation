  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 210.040 to replace the term \"institutions\" with \"facilities\"; establish that the Cabinet for Health and Family Services is responsible to provide care that includes emergency and other medical care provided outside of a state facility for patients in state-operated mental health facilities."
    }
  ],
