  "identifier": "HB204",
  "title": "AN ACT relating to duplexes.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Housing, Building, And Construction",
    "Land Use",
    "Local Government",
    "Local Mandate",
    "Planning And Zoning"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 100 to define \"duplex\"; allow duplexes as a permitted use in all residential zones; prohibit a planning unit from adopting or enforcing regulations that would exclude duplexes in residential zones or impose requirements or fees on duplexes different than those for single-family homes."
    }
  ],
