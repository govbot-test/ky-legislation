{
  "legislative_session": "2026RS",
  "identifier": "SB199",
  "title": "AN ACT relating to pesticide labeling.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Civil Actions",
