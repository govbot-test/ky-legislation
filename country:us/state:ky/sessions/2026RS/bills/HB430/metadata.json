  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 117 to define \"large public university campus\"; require county boards of elections to conduct election day and no-excuse in-person absentee voting on large public university campuses; provide that this Act shall be known as the Right to Vote at College Campuses Act."
    }
  ],
