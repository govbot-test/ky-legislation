  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 325.261 to include additional optional requirements to be considered for licensure; amend KRS 325.282 to allow practice privileges to a person who does not have an office located in the state and holds a valid license in good standing from another state if certain conditions are met; amend KRS 325.280 to conform; repeal KRS 325.263."
    }
  ],
