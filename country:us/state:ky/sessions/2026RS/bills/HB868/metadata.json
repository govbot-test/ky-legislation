  "identifier": "HB868",
  "title": "AN ACT relating to sex offender registrants.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children And Minors",
    "Corrections Impact",
