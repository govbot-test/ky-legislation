{
  "legislative_session": "2026RS",
  "identifier": "HB490",
  "title": "AN ACT relating to employment at public postsecondary education institutions and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Boards And Commissions",
    "Education, Higher",
    "Effective Dates, Emergency",
    "Universities And Colleges"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 164.360, 164.230, and 164.830 to allow for the removal of faculty members at public postsecondary education institutions for bona fide financial reasons; require the boards of regents and trustees of the institutions to establish the process for removal based on financial reasons with specified parameters; EMERGENCY."
    }
  ],
