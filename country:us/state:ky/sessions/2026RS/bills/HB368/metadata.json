  "identifier": "HB368",
  "title": "AN ACT relating to exempting the Commonwealth of Kentucky from the observance of daylight saving time.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Effective Dates, Delayed",
