  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 2 to exempt the Commonwealth of Kentucky from the advancement of time known as daylight saving time; require the Commonwealth of Kentucky and its political  subdivisions to at all times observe the standard time of the United States; EFFECTIVE October 31, 2026."
    }
  ],
