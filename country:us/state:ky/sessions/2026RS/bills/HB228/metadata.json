{
  "legislative_session": "2026RS",
  "identifier": "HB228",
  "title": "AN ACT relating to a tax credit for renters.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Landlord And Tenant",
    "Reports Mandated",
    "Taxation",
    "Taxation, Income--Individual"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 141 to establish a refundable qualified rent payment credit for taxable years beginning on or after January 1, 2027, but before January 1, 2031, in the amount of 25% of the qualified rent payments made during the taxable year, not to exceed $1,000; amend KRS 141.0205 to order the credit; amend KRS 131.190 to allow reporting by the Department of Revenue."
    }
  ],
