  "identifier": "HB498",
  "title": "AN ACT establishing the Adult Workforce Diploma Pilot Program.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
