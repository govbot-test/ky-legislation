  "identifier": "SB107",
  "title": "AN ACT relating to eminent domain for solar energy projects.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cooperatives",
    "Eminent Domain And Condemnation",
    "Energy",
