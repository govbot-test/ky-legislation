  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 216 to define terms; prohibit a health care provider from performing a pelvic, rectal, or prostate examination without the informed consent of the patient or the person authorized to make health care decisions for the patient; provide for certain exceptions including a court order; require violators to be subject to discipline by the appropriate professional licensing board or accrediting agency."
    }
  ],
