{
  "legislative_session": "2026RS",
  "identifier": "HB904",
  "title": "AN ACT relating to gaming.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Amusements And Recreations",
    "Business Entities And Organizations",
    "Charitable And Nonprofit Organizations",
    "Corrections Impact",
