  "legislative_session": "2026RS",
  "identifier": "HB419",
  "title": "AN ACT relating to the Kentucky Fire Commission.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Boards And Commissions",
    "Diseases",
    "Fire Prevention",
    "Firefighters And Fire Departments",
    "Public Officers And Employees"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 95A.020 to increase the Kentucky Fire Commission to 18 members by transferring the 4 ex officio members to full member status; provide for terms of office of the members not subject to gubernatorial appointment; amend KRS 95A.262 to specify that any reimbursement to the Kentucky Career and Technical College System for administrative activities is subject to the 5% reimbursement cap in KRS 94A.240; specify that cancer screening reimbursements can be made from revenues allocated to the Firefighters Foundation Program fund pursuant to KRS 42.190 and 136.392."
    }
  ],
