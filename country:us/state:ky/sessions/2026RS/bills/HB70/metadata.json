  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 186.4102 and 281A.170 to require the Transportation Cabinet to place a denotation on every new or renewal identity document issued after January 1, 2027, that indicates the status of the document holder as a citizen of the United States or a noncitizen authorized to be in the United States; amend KRS 186.531 to conform."
    }
  ],
