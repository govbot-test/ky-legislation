{
  "legislative_session": "2026RS",
  "identifier": "SB225",
  "title": "AN ACT relating to regulation of residential construction.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Advisory Boards, Commissions, And Committees",
    "Housing, Building, And Construction",
    "State Agencies"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 198B.030 to require the Department of Housing, Buildings and Construction to consider the effects of any proposed new or amended regulation on residential construction by conducting a cost-benefit analysis and an analysis to determine the impacts on the amount of residential construction; require the analyses to be submitted to the Housing, Buildings and Construction Advisory Committee and the Legislative Research Commission; establish a moratorium on the Department of Housing, Buildings and Construction altering or amending any state code in a way that would result in an increase in residential construction costs until January 1, 2029."
    }
  ],
