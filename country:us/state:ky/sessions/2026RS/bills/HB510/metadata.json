  "legislative_session": "2026RS",
  "identifier": "HB510",
  "title": "AN ACT relating to organ donation safety.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Deaths",
