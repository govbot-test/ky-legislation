  "identifier": "HCR107",
  "title": "A CONCURRENT RESOLUTION establishing the Charitable Gaming Modernization Task Force to study, review, and report on updates to Kentucky\u00e2\u0080\u0099s charitable gaming statutes and administrative regulations.",
  "from_organization": "~{\"classification\": \"lower\"}",
