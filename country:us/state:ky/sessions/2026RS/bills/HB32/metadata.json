  "identifier": "HB32",
  "title": "AN ACT relating to coverage for epinephrine devices.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Actuarial Analysis",
    "Children And Minors",
    "Drugs And Medicines",
    "Education, Higher",
