  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of Subchapter 12 of KRS Chapter 154 to create the Veteran Entrepreneur Program to be administered by the Office of Entrepreneurship; establish requirements and program details; amend KRS 154.12-277 and 154.12-278 to include the Veteran Entrepreneur Program; and amend KRS 154.12-330 to give preference to veterans in the issuance of small business loans."
    }
  ],
