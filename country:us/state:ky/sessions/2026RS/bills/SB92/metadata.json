  "identifier": "SB92",
  "title": "AN ACT relating to Medicaid coverage for palliative care.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Fiscal Note",
    "Health And Medical Services",
