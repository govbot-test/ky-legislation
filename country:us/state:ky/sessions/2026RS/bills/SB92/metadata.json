    "State Agencies"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 205 to require Medicaid coverage for palliative care services; establish eligibility criteria and service requirements; require the Department for Medicaid Services to promulgate administrative regulations; require the Cabinet for Health and Family Services or the Department for Medicaid Services to seek federal approval if it is determined that such approval is necessary; provide authorization from the General Assembly to make changes to the Medicaid program as required under KRS 205.5372(1)."
    }
  ],
