  "identifier": "HB260",
  "title": "AN ACT relating to nationally certified student support personnel.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education, Elementary And Secondary",
    "Education, Vocational",
