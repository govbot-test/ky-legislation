{
  "legislative_session": "2026RS",
  "identifier": "SB10",
  "title": "AN ACT proposing to amend Section 77 of the Constitution of Kentucky relating to limiting the Governor's ability to grant pardons and commute sentences.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
