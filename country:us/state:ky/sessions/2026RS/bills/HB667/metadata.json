  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 109.045 to change the definition of \"confidential business information\"; extend the prohibition on the release of confidential business information relating to solid waste management service companies to all persons acting on behalf of a county or waste management district; provide that confidential business information shall be exempt from disclosure under KRS 61.870 to 61.844; provide for remedial actions to be taken if confidential business information is released; provide for payment to a contractor for work that is uninfluenced by and independent from confidential business information."
    }
  ],
