  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 164.769 to establish a pilot program to provide scholarships to students pursuing a teaching career in a math- or science-related discipline to be administered by the Kentucky Higher Education Assistance Authority; establish scholarship recipient selection, award, and repayment process; appropriate $4,175,000 in each fiscal year of the 2026-2028 fiscal biennium to support the program; APPROPRIATION; EMERGENCY."
    }
  ],
