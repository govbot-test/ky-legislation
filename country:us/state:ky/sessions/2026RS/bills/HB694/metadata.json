  "identifier": "HB694",
  "title": "AN ACT relating to an income tax credit for qualified employers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections And Correctional Facilities, State",
