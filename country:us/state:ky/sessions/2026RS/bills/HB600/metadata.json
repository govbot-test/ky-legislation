  "legislative_session": "2026RS",
  "identifier": "HB600",
  "title": "AN ACT relating to the collection of delinquent tax bills.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Attorney, County",
