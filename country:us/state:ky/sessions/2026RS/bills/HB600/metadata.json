    "Taxation, Property"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 68 to authorize a county to utilize a consolidated procedure in the collection of delinquent tax bills; amend KRS 134.504 to require the allowance of a consolidated  procedure for the collection of delinquent taxes in the terms of a contract between the Department of Revenue and a county attorney; amend the fees a county attorney may receive in the process of litigation for the collection of a certificate of delinquency; amend KRS 91.481, 91.484, 91.487, 91.488, 91.4882, 91.4883, 91.4884, 91.4885, 91.494, 91.501, 91.504, 91.507, 91.511, 91.514, 91.517, 91.521, 91.527, 91.550, and 92.810 to make technical corrections."
    }
  ],
