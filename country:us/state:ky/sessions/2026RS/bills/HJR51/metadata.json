{
  "legislative_session": "2026RS",
  "identifier": "HJR51",
  "title": "A JOINT RESOLUTION applying for an Article V convention to propose amendments to the Constitution of the United States that impose fiscal restraints on the federal government, limit the power and jurisdiction of the federal government, and limit the terms of office for federal government officials and members of Congress.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "Budget And Financial Administration",
    "Constitution, U.S.",
    "Secretary Of State",
    "United States"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Apply to Congress under the provisions of Article V of the Constitution of the United States for the calling of a convention of the states limited to proposing amendments to the Constitution of the United States that impose fiscal restraint on the federal government, limit the powers and jurisdiction of the federal government, and limit the terms of office for its officials and members of Congress; direct the Secretary of State to send copies of the joint resolution to certain federal and state officials; state that the application should be continuing until the legislatures of at least two-thirds of the states have made applications on the subject."
    }
  ],
