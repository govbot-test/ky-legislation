  "identifier": "SJR75",
  "title": "A JOINT RESOLUTION directing the Public Service Commission to explore measures that would address affordability and the provision of essential utility services and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
