{
  "legislative_session": "2026RS",
  "identifier": "HB308",
  "title": "AN ACT relating to sex crimes.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections And Correctional Facilities, State",
    "Corrections Impact",
    "Crimes And Punishments",
    "Criminal Procedure",
    "Drugs And Medicines",
    "Probation And Parole"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 532 to provide that any person who has been convicted of, pled guilty to, or entered an Alford plea to a sex crime in which the victim was under the age of 12 shall undergo medroxyprogesterone acetate treatment; provide that treatment shall begin no later than 1 month before the person is released from custody; provide that treatment shall continue until the person is released from probation, parole, or postincarceration supervision; provide that the person shall be evaluated by a licensed physician prior to treatment to determine if the person is an appropriate candidate for treatment; provide that the Department of Corrections shall administer the treatment; authorize the Department of Corrections to promulgate administrative regulations to implement the requirements."
    }
  ],
