  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 337.010  to increase the applicable threshold of employees of retail stores and service industries from $95,000 to $500,000 average annual gross volume of sales for the employer; amend KRS 337.275 to incrementally raise minimum wage of hourly and tipped employees and require adherence to any future federal increase in excess of the new state wage rates; include anti-preemption language permitting local governments to establish minimum wage ordinances in excess of the state minimum wage."
    }
  ],
