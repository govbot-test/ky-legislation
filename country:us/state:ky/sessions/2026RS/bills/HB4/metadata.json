  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "\u00adCreate a new section of KRS Chapter 510 to establish the offense of grooming a minor; amend KRS 510.010 to define \"course of conduct,\" \"grooming behavior,\"  and \"sexual conduct\"; amend various sections to conform; make technical corrections."
    }
  ],
