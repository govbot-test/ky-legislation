  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 200 to define terms; establish the Kentucky Diaper Access Board and its functions related to the development of a state plan for the distribution of funds from the Kentucky diaper access trust fund; establish the Kentucky diaper access trust fund and the purposes for which funds are disbursed to diaper access programs in the Commonwealth."
    }
