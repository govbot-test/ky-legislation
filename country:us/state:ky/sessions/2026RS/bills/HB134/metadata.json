{
  "legislative_session": "2026RS",
  "identifier": "HB134",
  "title": "AN ACT relating to sexual assault nurse examiners.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Boards And Commissions",
    "Crime Victims",
    "Health And Medical Services",
    "Health Care Professionals",
