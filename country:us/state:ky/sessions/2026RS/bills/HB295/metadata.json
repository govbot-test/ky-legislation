  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 383 to prohibit landlords from charging screening fees without notice to the applicant; require screening criteria from landlords; require landlords to provide notice of denial to applicants; allow applicants to view the property before a security deposit is paid."
    }
