  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 341.005 to define \"certified mail,\" \"multi-factor authentication,\" and \"notice\"; creates a new section of KRS Chapter 341 to require any notice from the secretary of the Education and Labor Cabinet or any employer to employers or employees to be in writing and delivered by any method of governmental, commercial, or electronic delivery; require the secretary to provide employers and employees the option to receive only electronic notices; require the electronic notice system to utilize effective privacy controls, including multi-factor authentication procedures."
    }
  ],
