  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 278 to define terms; require the Public Service Commission to adopt rules and policies to prioritize securing affordable, reliable, and clean energy by prioritizing domestic fuel sources, prohibiting the use of critical materials sources or manufactured by a foreign adversary nation, giving preference to infrastructure and components built in the Commonwealth and the United States, and ensuring sufficient clean energy sources that are dispatchable and minimize disruptions; EFFECTIVE November 1, 2026."
    }
  ],
