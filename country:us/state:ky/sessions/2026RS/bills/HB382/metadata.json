  "identifier": "HB382",
  "title": "AN ACT relating to swimming pools.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Housing, Building, And Construction",
