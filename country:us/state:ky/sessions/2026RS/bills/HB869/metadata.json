{
  "legislative_session": "2026RS",
  "identifier": "HB869",
  "title": "AN ACT relating to fiscal matters and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties",
    "Economic Development",
    "Effective Dates, Emergency",
    "Reports Mandated",
    "Taxation",
