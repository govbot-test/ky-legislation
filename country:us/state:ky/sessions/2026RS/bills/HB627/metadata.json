  "identifier": "HB627",
  "title": "AN ACT relating to insurance.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Consumer Protection",
    "Contracts",
    "Corrections Impact",
