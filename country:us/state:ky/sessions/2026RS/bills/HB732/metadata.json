  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 336 to define terms; allow a public or private entity to contribute funds to a portable benefit plan as a form of compensation to a self-employed worker; prohibit using contributions to determine a worker's classification."
    }
  ],
