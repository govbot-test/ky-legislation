  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 176 to define \"resurfacing project'; require the Department of Highways to notify cities where resurfacing projects are located at least 60 days prior to the project letting date; specify contents of the notice; allow any affected city to submit comments on the project; require city to consider feedback from the city and issue a response."
    }
  ],
