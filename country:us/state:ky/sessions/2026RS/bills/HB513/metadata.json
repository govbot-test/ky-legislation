  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 157.320 and 157.360 to remove references to kindergarten full-time equivalent pupils in average daily attendance for program base funding purposes; amend KRS 158.030 and KRS 158.031 to conform; amend KRS 158.060 to remove language that allows for half-day kindergarten programs; EFFECTIVE July 1, 2027."
    }
  ],
