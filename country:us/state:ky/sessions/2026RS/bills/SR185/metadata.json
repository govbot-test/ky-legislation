  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Urge the Cabinet for Economic Development and the Tourism, Arts and Heritage Cabinet to work together to enhance economic development and tourism for Kentucky through the state park system; request the cabinets to present recommendation to the Interim Joint Committee on Economic Development and Workforce Investment."
    }
