  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 335B to allow universal recognition of occupational licenses and government certifications; include work experience as a basis for licensure or certification; explicity include military personnel and their spouses; provide that the Act may be cited as the Universal Recognition of Occupational Licenses Act."
    }
  ],
