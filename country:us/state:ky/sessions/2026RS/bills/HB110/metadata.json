  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 199.470 to prohibit an unmarried couple from jointly adopting any child; amend KRS 199.520 to provide that an adoption of a child shall not terminate the legal relationship between the adopted child and the biological parent when the adopting parent is the legally married spouse of the biological parent."
    }
  ],
