  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 243.042 to authorize a qualified historic site licensee to sell alcoholic beverages by the package in a jurisdiction that has authorized the sale of distilled spirits and wine by the package; amend KRS 243.238 to allow a qualified historic site license to be added to the list of approved licenses that are eligible for obtaining a special permit to sell limited barrel picks; amend KRS 243.110 to conform."
    }
  ],
