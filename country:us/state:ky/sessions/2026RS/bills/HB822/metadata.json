  "identifier": "HB822",
  "title": "AN ACT relating to coverage for colorectal cancer examinations and laboratory tests and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Effective Dates, Emergency",
