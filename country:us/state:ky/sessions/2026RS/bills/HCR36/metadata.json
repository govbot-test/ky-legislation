  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Establish the Child Welfare and Family Court Reform Task Force; establish duties and membership; require the task force to meet monthly during the 2026 Interim of the General Assembly and submit a report to the Legislative Research Commission by December 1, 2026."
    }
  ],
