  "identifier": "SB13",
  "title": "AN ACT relating to planning commission membership.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advisory Boards, Commissions, And Committees",
