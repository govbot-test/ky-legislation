{
  "legislative_session": "2026RS",
  "identifier": "HB184",
  "title": "AN ACT relating to health savings account-qualified insurance plans.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Federal Laws And Regulations",
    "Insurance, Health",
    "Short Titles And Popular Names",
    "State Employees"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of Subtitle 1 of KRS Chapter 304 to limit the application of cost-sharing requirements that would result in a health insurance policy, certificate, plan, or contract losing its health savings account-qualified status under federal law; create a new section of KRS Chapter 18A to subject cost-sharing requirements in that chapter to applicability limitation; provide that applicability limitation applies to policies, certificates, plans, and contracts issued or renewed on or after the effective date of the Act; provide purpose of Section 1 of the Act; state the that Section 1 of the Act may be cited as the Health Savings Account State-Federal Regulatory Coordination Model Act."
    }
  ],
