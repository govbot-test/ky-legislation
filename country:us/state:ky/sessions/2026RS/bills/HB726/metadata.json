  "identifier": "HB726",
  "title": "AN ACT relating to telehealth coverage.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education, Higher",
    "Health And Medical Services",
