  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 158.1415 to require a school district to adopt health curricula that includes human growth and development instruction that meets specific criteria; set restrictions for the instruction that grants parents an opportunity to review materials and opt their child out of instruction."
    }
  ],
