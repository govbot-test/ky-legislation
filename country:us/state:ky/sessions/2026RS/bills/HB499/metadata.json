  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 138.470 to exempt from motor vehicle usage tax any motor vehicle purchased by current members of the Kentucky National Guard or reserve component, motor vehicles brought into the Commonwealth that were sold by a dealer in another state to a member of the Armed Forces on duty in the Commonwealth while that person was on temporary duty in another state, and motor vehicles registered outside the state by a veteran or member of the United States Armed Forces that were purchased while that person was a member of the Armed Forces."
    }
  ],
