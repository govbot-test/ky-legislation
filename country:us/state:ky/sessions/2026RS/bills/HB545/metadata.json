  "identifier": "HB545",
  "title": "AN ACT relating to a tax credit for alternative jet fuel.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
