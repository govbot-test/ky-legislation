  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 454.460 under the Uniform Public Expression Protection Act to define term; amend KRS 454.478, relating to court costs under the Uniform Public Expression Protection Act to require that the court make a finding that a party acted in bad faith prior to awarding court costs, reasonable attorney's fees, and reasonable litigation expenses."
    }
  ],
