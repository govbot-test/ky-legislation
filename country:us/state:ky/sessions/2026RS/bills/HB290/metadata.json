  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 172.100 and 172.200, relating to county law libraries, to ensure that law library funds can be expended for subscriptions to computer-assisted legal research, internet access, and computers and related equipment."
    }
  ],
