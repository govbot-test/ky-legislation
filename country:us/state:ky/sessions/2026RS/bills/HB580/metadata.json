  "identifier": "HB580",
  "title": "AN ACT relating to a first-generation homebuyer trust fund program.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Budget And Financial Administration",
    "Housing, Building, And Construction",
