  "legislative_session": "2026RS",
  "identifier": "SB102",
  "title": "AN ACT relating to the Kentucky State Police and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Peace Officers And Law Enforcement",
    "Police, State",
    "Public Safety",
    "Retirement And Pensions"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 16.197 to allow an individual previously appointed to Trooper R Class or commercial vehicle enforcement officer R class to return to service with the Department of Kentucky State Police after 1 month of separation from service but no more than 60 months following the individual's latest separation date from service."
    }
  ],
