  "legislative_session": "2026RS",
  "identifier": "SB155",
  "title": "AN ACT relating to animal health emergencies and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Animals, Livestock, And Poultry",
    "Diseases",
    "Fish And Wildlife",
    "Governor",
