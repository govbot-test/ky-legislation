  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 258.265 to exempt a working livestock dog found at large from seizure by a peace officer or animal control officer when unaccompanied and unrestrained by its owner between sunset and sunrise or when engaged in a lawful working activity."
    }
  ],
