{
  "legislative_session": "2026RS",
  "identifier": "HB139",
  "title": "AN ACT relating to elections and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Attorney, Commonwealth's",
    "Counties",
    "County Clerks",
    "Education, Elementary And Secondary",
    "Effective Dates, Emergency",
    "Elections And Voting",
