{
  "legislative_session": "2026RS",
  "identifier": "SB5",
  "title": "AN ACT relating to Kentucky-grown agricultural product procurement and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Education, Elementary And Secondary",
    "Federal Laws And Regulations",
    "Foods And Beverages",
    "Public Procurement"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 158 to define \"agricultural product\" and \"Kentucky-grown agricultural product\"; allow a local school board or local school district participating in any of the United States Department of Agriculture Child Nutrition Programs to purchase Kentucky-grown agricultural products in accordance with federal law."
    }
  ],
