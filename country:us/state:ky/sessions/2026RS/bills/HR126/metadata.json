  "identifier": "HR126",
  "title": "A RESOLUTION urging the federal government to provide states with increased flexibility to design and test innovative approaches that reduce barriers to employment and promote economic self-sufficiency among individuals and families receiving public assistance.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
