    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 161.155 to allow school district employees to use sick leave for observance of religious holidays not otherwise included on the school's calendar, provided the employee submits a personal statement verifying the observance and gives advance notice to the district."
    }
