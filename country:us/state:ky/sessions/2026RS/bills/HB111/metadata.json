  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 257 to allow the determination and implementation of an on-farm animal health care or animal health production practice to be made solely by a farmer and his or her veterinarian."
    }
  ],
