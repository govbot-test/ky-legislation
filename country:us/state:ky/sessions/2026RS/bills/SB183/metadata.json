{
  "legislative_session": "2026RS",
  "identifier": "SB183",
  "title": "AN ACT relating to the regulation of proxy advisory services.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Attorney General",
    "Business Entities And Organizations",
    "Civil Actions",
    "Commerce",
    "Consumer Protection",
    "Fiduciaries",
    "Financial Responsibility",
    "Investments",
    "Retirement And Pensions"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 367 to define terms; require proxy advisors to notify and disclose certain information to shareholders in a company doing business in Kentucky and to the company that is subject to the proxy advisory service when the proxy advisor is not acting solely in the interest of shareholders, as defined, or is providing materially different advice to shareholders regarding a proxy proposal or company proposal; declare that failure to notify or disclose required information is an unfair, false, misleading, or deceptive trade practice in violation of KRS 367.170; establish remedies including civil actions; apply to proxy advisory services provided on or after the effective date of the Act."
    }
  ],
