  "legislative_session": "2026RS",
  "identifier": "HB43",
  "title": "AN ACT relating to deputy coroner training.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Coroners",
    "Counties",
    "Local Government",
