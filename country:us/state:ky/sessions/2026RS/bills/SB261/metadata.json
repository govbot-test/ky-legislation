  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 67.083 to allow fiscal courts to provide for the care and maintenance of pedestrian swinging bridges that are available for recreation and public enjoyment; amend KRS 411.190 to give liability protections to owners of land leased to a local government that maintains pedestrian swinging bridges that are available for recreation and public enjoyment on the land."
    }
  ],
