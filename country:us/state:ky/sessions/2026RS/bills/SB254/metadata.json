  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 65 to require local governments to establish a program to waive fines, fees, and interest associated with a property that has been donated to a qualifying donee; amend KRS 65.355 to require a local government that creates a land bank authority to establish a program to grant property assessment moratoriums pursuant to KRS 99.595 to 99.605."
    }
  ],
