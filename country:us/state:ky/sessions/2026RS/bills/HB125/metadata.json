  "identifier": "HB125",
  "title": "AN ACT relating to firearms possession by domestic abusers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Courts",
    "Crimes And Punishments",
