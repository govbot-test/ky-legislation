  "identifier": "HB52",
  "title": "AN ACT relating to school curriculum.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Children And Minors",
