  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create new sections of KRS Chapter 6 to provide for the selection and oversight of Article V commissioners if an Article V convention is called and the Commonwealth is a participant; define terms; establish rules and procedures for appointing, recalling, or filling vacancies for delegates and alternate delegates to Article V conventions; establish duties of delegates and oath requirements; rules and procedures for adoption of instructions to the delegates for an Article V convention; create guidelines for invalidation an unauthorized vote and penalties for an unauthorized vote; establish procedures and the composition of Article V Oversight Committee membership; EMERGENCY."
    }
  ],
