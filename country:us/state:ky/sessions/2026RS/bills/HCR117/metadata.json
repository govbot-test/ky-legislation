  "identifier": "HCR117",
  "title": "A CONCURRENT RESOLUTION relating to the establishment of a Beauty Industry Law Task Force to complete a detailed review of the current laws to ensure alignment throughout the relevant statutes and administrative regulations.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
