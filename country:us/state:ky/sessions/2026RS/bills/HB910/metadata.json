  "identifier": "HB910",
  "title": "AN ACT relating to drug paraphernalia.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crimes And Punishments",
    "Criminal Procedure",
    "Drugs And Medicines"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 218A.500 to provide that drug testing products that are used or intended for use to determine whether a substance contains a controlled substance, synthetic drug, or any chemical or compound that may cause physical harm or death shall not be deemed drug paraphernalia."
    }
  ],
