  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 17 to define terms; require the Justice and Public Safety Cabinet to establish and maintain a domestic violence offender registry; limit the registry to persistent domestic violence offenders; require registrants to pay a $150 registration fee."
    }
