  "identifier": "HB455",
  "title": "AN ACT relating to artificial intelligence and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advertising",
    "Boards And Commissions",
