{
  "legislative_session": "2026RS",
  "identifier": "SB345",
  "title": "AN ACT relating to Medicaid waiver program coverage for community interveners.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Blind Or Deaf Persons",
    "Medicaid"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 205 to define \"community intervener\"; require the Michelle P. waiver program to cover community intervener services if approved by the federal Centers for Medicare and Medicaid Services; require the Department for Medicaid Services to promulgate administrative regulations; require the cabinet or the Department for Medicaid Services to seek federal approval if it is determined that such approval is necessary; provide authorization from the General Assembly to make changes in the Medicaid program as required under KRS 205.5372(1)."
    }
  ],
