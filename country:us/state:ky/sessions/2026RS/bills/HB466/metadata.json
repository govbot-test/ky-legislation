  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 214.034 to delete hepatitis B from the list of required immunizations for children; prohibit additional immunizations from being required by the Cabinet for Health and Family Services without the approval of the General Assembly; delete requirement for hepatitis B immunization for sixth grade school attendance."
    }
  ],
