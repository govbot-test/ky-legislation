  "identifier": "HB713",
  "title": "AN ACT relating to workplace violence against health care professionals.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health And Medical Services",
    "Health Care Professionals",
