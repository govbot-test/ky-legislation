  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 278.160 to prohibit the collection of charges and fees for other governmental units by an investor-owned electric utility; prohibit the collection of certain surcharges and amounts that are not directly and exclusively related to the provision of electric service; require investor owned utilities to file new tariffs 90 days after December 30, 2026; EFFECTIVE December 30, 2026."
    }
  ],
