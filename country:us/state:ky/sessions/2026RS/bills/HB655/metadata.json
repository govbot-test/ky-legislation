  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 304.17C-085 to modify the definition of \"covered services\" to exclude services and materials for which reimbursement would be available but for the application of the enrollee's contractual limitation of an annual maximum benefit; prohibit contractual waivers; make technical amendments; direct that the Act applies to contracts issued or renewed on or after the effective date of the Act."
    }
  ],
