  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 121.175 to allow the use of campaign funds to pay for the reasonable costs of security measures for a state candidate, officeholder, member of his or her family, and employees of the candidate's campaign or the officeholder's office as long as the amount does not exceed $15,000 per fiscal year; define \"security measure\" and \"usual and normal charge.\""
    }
  ],
