  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 164.092 to change the membership of the postsecondary education working group of the Council on Postsecondary Education; require the working group to convene on a calendar year basis rather than a fiscal year basis; EMERGENCY."
