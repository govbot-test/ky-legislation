  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 525.010 to define \"religious organization\" and \"religious service\"; make technical corrections to existing definitions; create a new section of KRS Chapter 525 to establish the crime of interference with a religious service as a Class A misdemeanor; create a new section of KRS Chapter 411 to establish a civil cause of action for interference with a religious service; amend KRS 525.200 to conform."
    }
  ],
