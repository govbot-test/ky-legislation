  "identifier": "HB877",
  "title": "AN ACT proposing to amend Section 170 of the Constitution of Kentucky relating to exempting property from taxation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
