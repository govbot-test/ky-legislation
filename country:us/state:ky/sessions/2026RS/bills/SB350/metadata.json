  "identifier": "SB350",
  "title": "AN ACT relating to the abolition of the death penalty.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections Impact",
    "Courts",
