  "identifier": "HB267",
  "title": "AN ACT relating to welcome centers and rest areas.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Advertising",
    "Highways, Streets, And Bridges",
