{
  "legislative_session": "2026RS",
  "identifier": "HB776",
  "title": "AN ACT relating to health care services and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Regulations And Proceedings",
    "Boards And Commissions",
    "Business Entities And Organizations",
    "Commerce",
