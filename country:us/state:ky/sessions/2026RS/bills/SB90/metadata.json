  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 533.272 to extend the behavioral health conditional dismissal program pilot project until January 1, 2031; amend KRS 533.288 to extend the Behavioral Health Conditional Dismissal Program Implementation Council until December 31, 2031; amend 2022 Ky. Acts ch. 230, sec. 13, to establish that moneys appropriated for the behavioral health conditional dismissal program through June 30, 2026, shall not lapse and shall be carried forward."
    }
  ],
