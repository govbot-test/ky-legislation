  "legislative_session": "2026RS",
  "identifier": "HB214",
  "title": "AN ACT relating to disabled veterans.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Disabilities",
    "Funds",
