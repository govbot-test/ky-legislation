  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 186 to require the Department of Kentucky State Police, in partnership with the Kentucky Department of Education, to operate a pilot project from September 1, 2027, to June 30, 2029, to provide instruction permit testing in 1 public high school in each congressional district in the Commonwealth; set requirements for the pilot project; require that the state police report to the Legislative Research Commission by October 31, 2027, and annually thereafter as long as the pilot project continues, to provide data and the pilot project's effect on existing testing efforts."
    }
  ],
