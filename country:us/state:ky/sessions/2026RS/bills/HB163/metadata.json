  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 532.025 to include abuse of a corpse of the victim of kidnapping or murder by engaging in deviate sexual intercourse, sexual intercourse, or sexual contact as an aggravating circumstance; provide that the Act may be cited as Angela's Law."
    }
