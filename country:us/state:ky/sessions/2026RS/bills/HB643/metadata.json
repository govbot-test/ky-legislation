  "identifier": "HB643",
  "title": "AN ACT relating to school safety.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education, Elementary And Secondary",
    "Peace Officers And Law Enforcement",
