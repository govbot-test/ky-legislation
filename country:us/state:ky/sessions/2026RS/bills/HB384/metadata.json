  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 177.320 and 177.365, relating to the allocation of a portion of motor fuel tax revenue to county road aid funds and municipal road aid funds, to change the revenue-sharing formula on the portion of revenue available for revenue sharing that exceeds $775 million in any fiscal year from 18.3% for counties and 7.7% for cities to 13% for each fund; make technical corrections; amend KRS 176.241, 178.010, 179.010, and 189.503 to conform; EMERGENCY."
    }
  ],
