  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 610 to define terms; prohibit the use of deceptive methods when a child is being interrogated; create a new rule of evidence to limit the admissibility of statements made during the interrogation of a child in violation of statute."
    }
