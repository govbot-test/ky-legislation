  "identifier": "HB40",
  "title": "AN ACT relating to providing free feminine hygiene products to elementary and secondary students.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children And Minors",
    "Education, Elementary And Secondary",
