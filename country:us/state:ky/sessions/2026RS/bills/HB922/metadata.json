  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 164 to create the physician recruitment and retention program to provide loan repayment to eligible medical students; define terms; specify the Kentucky Higher Education Assistance Authority may provide awards to eligible students; require 10 years of qualified medical service; require repayment if services are not rendered; specify that failure to meet repayment obligations may be cause for revocation of a medical license at the discretion of the Kentucky Board of Medical Licensure."
    }
  ],
