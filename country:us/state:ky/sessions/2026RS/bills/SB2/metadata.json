  "legislative_session": "2026RS",
  "identifier": "SB2",
  "title": "AN ACT relating to school administrators and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education, Elementary And Secondary",
    "Education, Finance"
  ],
  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 157.350 to provide that in order to be eligible to receive support education excellence in Kentucky funds a school district shall not provide the superintendent or any administrator a percentage pay increase greater than the average percentage pay increase provided to classroom teachers within the district; amend KRS 156.070 to conform."
    }
  ],
