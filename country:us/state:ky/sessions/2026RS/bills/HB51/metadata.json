  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Create a new section of KRS Chapter 6 to require the Legislative Research Commission to prepare a family impact statement for every bill or resolution introduced during a regular or extraordinary session of the Kentucky General Assembly; define terms; establish procedures."
    }
