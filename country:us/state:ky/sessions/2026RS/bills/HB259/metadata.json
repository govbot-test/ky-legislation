  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Propose to amend Sections 32, 72, 91, 100, and 122 of the Constitution of Kentucky to require candidates for the General Assembly, Governor, Lieutenant Governor, Treasurer, Auditor of Public Accounts, Commissioner of Agriculture, Secretary of State, Attorney General, county clerk, Circuit Court clerk, Commonwealth\u00e2\u0080\u0099s attorney, county attorney, District Judge, Circuit Judge, Court of Appeals Judge, and Justice of the Supreme Court to be a natural born citizen of the United States and a national of only the United States in order to hold each respective office; provide ballot language; submit to voters for ratification or rejection."
    }
  ],
