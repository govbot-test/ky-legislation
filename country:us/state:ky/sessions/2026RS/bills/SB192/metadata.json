  "identifier": "SB192",
  "title": "AN ACT relating to local entities and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Accountants",
    "Advertising",
    "Auditor Of Public Accounts",
    "Audits And Auditors",
    "Cities",
    "Financial Responsibility",
