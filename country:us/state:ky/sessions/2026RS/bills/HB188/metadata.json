  "abstracts": [
    {
      "note": "Summary of Original Version",
      "abstract": "Amend KRS 508.025 to expand assault in the third degree to include causing or attempting to cause physical injury to a healthcare provider in a jail, penitentiary, or local or state correctional or detention facility; amend KRS 65.1591 to add jailers, deputy jailers, and correctional officers employed by a local detention center, local correctional facility, or regional jail to the list of public safety employees eligible to participate in a peer support counseling program."
    }
  ],
